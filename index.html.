<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Pago con Zelle</title>

<style>
body{
margin:0;
font-family:Arial,sans-serif;
background:linear-gradient(135deg,#5f259f,#7d3cff);
display:flex;
justify-content:center;
align-items:center;
height:100vh;
}

.card{
background:#fff;
padding:35px;
border-radius:25px;
max-width:360px;
width:90%;
text-align:center;
box-shadow:0 15px 40px rgba(0,0,0,.3);
}

.logo{
font-size:48px;
font-weight:bold;
color:#5f259f;
margin-bottom:10px;
}

h1{
margin:0;
color:#333;
}

h2{
color:#5f259f;
margin:15px 0;
}

.number{
font-size:28px;
font-weight:bold;
margin:25px 0;
}

button{
background:#5f259f;
color:white;
border:none;
padding:15px;
width:100%;
border-radius:12px;
font-size:18px;
cursor:pointer;
}

button:hover{
background:#4a1f80;
}

.footer{
margin-top:25px;
color:#666;
font-size:14px;
}
</style>

</head>

<body>

<div class="card">

<div class="logo">Zelle</div>

<h1>Pago por Zelle</h1>

<h2>Rosibel</h2>

<div class="number" id="num">
502-468-0575
</div>

<button onclick="copiar()">
📋 Copiar número
</button>

<div class="footer">
Gracias por tu compra 💜
</div>

</div>

<script>

function copiar(){
navigator.clipboard.writeText("502-468-0575");
alert("Número copiado correctamente.");
}

</script>

</body>
</html>
